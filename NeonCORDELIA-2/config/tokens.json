[
    {"type": "RHYTHM", "pattern": "(eu|jex|hex):"},
    {"type": "EVENT", "pattern": "event:"},
    {"type": "PRINT", "pattern": "print"},
    {"type": "SCALA", "pattern": "scala\\.\\w+@\\w+|scala\\.\\w+"},
    {"type": "INSTR", "pattern": "@\\w+"},
    {"type": "ROUTING", "pattern": "\\.[a-z]\\w+"},
    {"type": "FUNC", "pattern": "\\w+(?=\\()"},
    {"type": "LPAREN", "pattern": "\\("},
    {"type": "RPAREN", "pattern": "\\)"},
    {"type": "GKVAR", "pattern": "gk\\w+"},
    {"type": "GIVAR", "pattern": "gi\\w+"},
    {"type": "NUMBER_FLOAT", "pattern": "\\d+\\.\\d+|\\.\\d+"},
    {"type": "NUMBER_INT", "pattern": "\\d+"},
    {"type": "COMMA", "pattern": ","},
    {"type": "COLON", "pattern": ":"},
    {"type": "COMMENT", "pattern": ";"},
    {"type": "SYMBOL", "pattern": "[^\\w\\s]"},
    {"type": "WORD", "pattern": "\\w+"},
    {"type": "EMPTYLINE", "pattern": "\\n$"},
    {"type": "NEWLINE", "pattern": "\\n"}
